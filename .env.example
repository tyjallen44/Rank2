# Web server password (required to access the web UI)
ACCESS_PASSWORD=

# Claude API (required for analysis reports)
ANTHROPIC_API_KEY=

# Google Places API key (required to ground the AI Visibility Score in real
# Google ratings/review counts; without it, Google reads come back unverified).
# Enable the "Places API (New)" on the key in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# Your product dashboard
DASHBOARD_BASE_URL=
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
DASHBOARD_API_BASE_URL=
DASHBOARD_API_KEY=

# DuckDB file path (default: local file)
DB_PATH=rank2.duckdb
